diff --git a/Makefile.pre.in b/Makefile.pre.in
index fa99dd86c4..53044b22a2 100644
--- a/Makefile.pre.in
+++ b/Makefile.pre.in
@@ -47,9 +47,11 @@
 GITBRANCH=	@GITBRANCH@
 PGO_PROF_GEN_FLAG=@PGO_PROF_GEN_FLAG@
 PGO_PROF_USE_FLAG=@PGO_PROF_USE_FLAG@
+LLVM_PROFDATA=@LLVM_PROFDATA@
 LLVM_PROF_MERGER=@LLVM_PROF_MERGER@
 LLVM_PROF_FILE=@LLVM_PROF_FILE@
 LLVM_PROF_ERR=@LLVM_PROF_ERR@
+LLVM_MERGED_DATA_FILE=@LLVM_MERGED_DATA_FILE@
 DTRACE=         @DTRACE@
 DFLAGS=         @DFLAGS@
 DTRACE_HEADERS= @DTRACE_HEADERS@
@@ -508,6 +510,8 @@
 	# Next, run the profile task to generate the profile information.
 	$(MAKE) run_profile_task
 	$(MAKE) build_all_merge_profile
+	# Show details of profile coverage to aid PGO debugging.
+	$(LLVM_PROFDATA) show --detailed-summary --topn=500 $(LLVM_MERGED_DATA_FILE)
 	# Remove profile generation binary since we are done with it.
 	$(MAKE) clean-retain-profile
 	# This is an expensive target to build and it does not have proper
